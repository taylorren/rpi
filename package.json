{
  "name": "rpi",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --parallel --filter @rpi/web --filter @rpi/api run dev",
    "dev:all": "pnpm --parallel --filter @rpi/web --filter @rpi/api run dev",
    "dev:web": "pnpm --filter @rpi/web run dev",
    "dev:api": "pnpm --filter @rpi/api run dev",
    "build": "pnpm -w -r run build",
    "typecheck": "pnpm -w -r run typecheck",
    "db:push": "pnpm --filter @rpi/db run db:push"
  },
  "packageManager": "pnpm@11.5.1+sha512.93f7b57422ea7068257235b4c16eb60762eb68e1dc23723199cc739043ea9be2c4143274a399d8c6defa2b1176226d9ca1c4b63482d6200c1a8fbaa78c1d1485"
}
